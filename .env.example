# ===================================
# وكيل المتصفح الذكي - متغيرات البيئة
# Browser AI Agent - Environment Variables
# ===================================

# مفتاح OpenAI API (مطلوب) / OpenAI API Key (required)
# احصل على مفتاحك من: https://platform.openai.com/api-keys
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# نموذج OpenAI المستخدم (اختياري) / OpenAI model to use (optional)
# الافتراضي: gpt-4o / Default: gpt-4o
# OPENAI_MODEL=gpt-4o

# الحد الأقصى لعدد خطوات الوكيل (اختياري) / Max agent iterations (optional)
# الافتراضي: 20 / Default: 20
# MAX_ITERATIONS=20

# منفذ خادم API (اختياري) / API server port (optional)
# الافتراضي: 3001 / Default: 3001
# API_PORT=3001

# منفذ خادم WebSocket (اختياري) / WebSocket server port (optional)
# الافتراضي: 9009 / Default: 9009
# WS_PORT=9009
